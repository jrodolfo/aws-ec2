#!/usr/bin/env bash
set -euo pipefail

usage() {
    cat <<'EOF'
Usage: check-updates

Check whether Amazon Linux release updates are available.

Notes:
  - This helper expects a dnf-based system such as Amazon Linux.
  - If your environment requires elevated privileges, run it with sudo.
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    usage
    exit 0
fi

if ! command -v dnf >/dev/null 2>&1; then
    echo "check-updates requires dnf and is intended for Amazon Linux hosts." >&2
    exit 1
fi

echo "==============================="
echo "Release Update Check"
echo "==============================="
echo "Checking for available release updates..."
output=""
status=0

set +e
output="$(dnf check-release-update 2>&1)"
status=$?
set -e

if [[ "${status}" -ne 0 ]]; then
    echo
    echo "Release update check failed:"
    printf '%s\n' "${output}" >&2
    exit "${status}"
fi

if [[ -n "${output}" ]]; then
    echo
    printf '%s\n' "${output}"
    echo
    echo "Release updates are available."
else
    echo
    echo "No newer Amazon Linux release is currently available."
fi
